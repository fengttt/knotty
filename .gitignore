# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Dataset working dir (large extracted archives; source archives are tracked via LFS).
# Ignore contents but leave the directory itself un-ignored so negations below
# can re-include specific files. (gitignore can't re-include a file whose
# parent directory is fully excluded.)
dataset/*
# Re-include source archives tracked via LFS.
!dataset/*.zip
!dataset/*.tar.gz
!dataset/*.xls
!dataset/*.xlsx
# Re-include the zipped knot_info JSON tracked via LFS.
!dataset/knot_info.json.zip
# Local-only working file; not tracked.
dataset/knot_polys.xlsx

# Editor/IDE
# .idea/
# .vscode/

# Local tooling / runtime logs
.claude/
.mcp.json
*.log

# Build artifacts
/knotty
/_site

